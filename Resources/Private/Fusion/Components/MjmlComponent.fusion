prototype(KaufmannDigital.EmailEditing:MjmlComponent) < prototype(Neos.Fusion:Component) {

    mjmlRenderer = ''
    additionalStyles = Neos.Fusion:DataStructure


    renderer.@process.append = Neos.Fusion:Value {
        value = ${'<mj-raw><style type="text/css">' + Array.join(props.additionalStyles, '') +'</style></mj-raw>' + value}
        @if.condition = ${Array.length(props.additionalStyles) > 0}
    }
}
